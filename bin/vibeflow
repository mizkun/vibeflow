#!/bin/bash
set -euo pipefail

# VibeFlow CLI
# Usage: vibeflow <command> [options]

# Resolve symlinks to find the real framework directory
resolve_framework_dir() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ $source != /* ]] && source="$dir/$source"
  done
  local bin_dir="$(cd -P "$(dirname "$source")" && pwd)"
  echo "$(dirname "$bin_dir")"
}

FRAMEWORK_DIR="$(resolve_framework_dir)"
VERSION=$(cat "${FRAMEWORK_DIR}/VERSION" 2>/dev/null || echo "unknown")

# Color output
RED='\033[0;31m'
BLUE='\033[0;34m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

usage() {
  echo ""
  echo -e "${BLUE}VibeFlow${NC} v${VERSION} — AI-driven development methodology for Claude Code"
  echo ""
  echo "Usage: vibeflow <command> [options]"
  echo ""
  echo "Commands:"
  echo "  setup       新規プロジェクトをセットアップ"
  echo "  upgrade     既存プロジェクトを最新バージョンにアップグレード"
  echo "  generate    スキーマからプロジェクトファイルを生成"
  echo "  version     バージョン情報を表示"
  echo "  doctor      環境の問題を診断"
  echo "  help        このヘルプを表示"
  echo ""
  echo "Setup options:"
  echo "  vibeflow setup [options]"
  echo "    --force              確認をスキップ"
  echo "    --no-backup          バックアップをスキップ"
  echo "    --with-e2e           E2E テスト付きでセットアップ"
  echo ""
  echo "Upgrade options:"
  echo "  vibeflow upgrade [options]"
  echo "    --dry-run            変更を実行せず、何が行われるかを表示"
  echo "    --force              確認をスキップ"
  echo "    --no-backup          バックアップをスキップ"
  echo ""
  echo "Generate options:"
  echo "  vibeflow generate [options]"
  echo "    --target <name>      特定ターゲットのみ生成 (hooks|settings|policy|docs|claude_md|manifest)"
  echo "    --diff               変更予定を表示（ファイルは書き込まない）"
  echo "    --schema-dir <dir>   スキーマディレクトリ（デフォルト: \$FRAMEWORK_DIR/core/schema）"
  echo ""
  echo "Doctor options:"
  echo "  vibeflow doctor [options]"
  echo "    --json               JSON 形式で出力"
  echo "    --strict             WARN も非ゼロ終了にする"
  echo ""
  echo "Examples:"
  echo "  mkdir my-project && cd my-project && vibeflow setup"
  echo "  cd existing-project && vibeflow upgrade"
  echo "  cd existing-project && vibeflow upgrade --dry-run"
  echo "  cd existing-project && vibeflow generate"
  echo "  cd existing-project && vibeflow generate --target hooks"
  echo "  cd existing-project && vibeflow generate --diff"
  echo ""
}

cmd_version() {
  echo "VibeFlow v${VERSION}"
  echo "Framework: ${FRAMEWORK_DIR}"

  if [ -f ".vibe/version" ]; then
    local project_version=$(cat .vibe/version | tr -d '[:space:]')
    echo "Project:   v${project_version} ($(pwd))"

    if [ "$project_version" != "$VERSION" ]; then
      echo ""
      echo -e "${YELLOW}⚠ プロジェクトがフレームワークより古いバージョンです${NC}"
      echo "  vibeflow upgrade を実行してください"
    fi
  fi
}

cmd_doctor() {
  # Delegate to core/doctor.py for manifest-aware integrity checks
  python3 "${FRAMEWORK_DIR}/core/doctor.py" \
    --project-dir "$(pwd)" \
    --schema-dir "${FRAMEWORK_DIR}/core/schema" \
    --framework-dir "${FRAMEWORK_DIR}" \
    "$@"
}

cmd_generate() {
  local SCHEMA_DIR="${FRAMEWORK_DIR}/core/schema"
  local PROJECT_DIR="$(pwd)"
  local GEN_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --schema-dir)
        SCHEMA_DIR="$2"
        shift 2
        ;;
      --target)
        GEN_ARGS+=("--target" "$2")
        shift 2
        ;;
      --diff)
        GEN_ARGS+=("--diff")
        shift
        ;;
      *)
        echo "Unknown generate option: $1"
        exit 1
        ;;
    esac
  done

  python3 "${FRAMEWORK_DIR}/core/generators/generate_all.py" \
    --schema-dir "$SCHEMA_DIR" \
    --project-dir "$PROJECT_DIR" \
    --framework-dir "$FRAMEWORK_DIR" \
    "${GEN_ARGS[@]}"
}

cmd_setup() {
  bash "${FRAMEWORK_DIR}/setup_vibeflow.sh" "$@"
}

cmd_upgrade() {
  bash "${FRAMEWORK_DIR}/upgrade_vibeflow.sh" "$@"
}

# --- Main routing ---

COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
  setup)    cmd_setup "$@" ;;
  upgrade)  cmd_upgrade "$@" ;;
  generate) cmd_generate "$@" ;;
  version)  cmd_version ;;
  doctor)   cmd_doctor "$@" ;;
  help|--help|-h)  usage ;;
  *)
    echo "Unknown command: $COMMAND"
    echo "Run 'vibeflow help' for usage"
    exit 1
    ;;
esac
